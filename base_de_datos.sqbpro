SELECT
    Venta.IdVenta,
    Cliente.Nombre,
    Cliente.Apellido,
    Computadora.Nombre AS Computadora,
    Computadora.Marca,
    Venta.Cantidad,
    Venta.Fecha
FROM Venta
INNER JOIN Cliente
ON Venta.IdCliente = Cliente.IdCliente
INNER JOIN Computadora
ON Venta.IdComputadora = Computadora.IdComputadora;</sql><current_tab id="0"/></tab_sql></sqlb_project>
